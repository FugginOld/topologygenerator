# Persistent topology + telemetry reporting agent (systemd).
# Edit User= and the path, then:
#   sudo cp systemd/topology-agent.service /etc/systemd/system/
#   sudo systemctl daemon-reload
#   sudo systemctl enable --now topology-agent
#   journalctl -u topology-agent -f      # watch it
[Unit]
Description=Topology reporting agent (pushes hardware map + live telemetry)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=YOUR_USER
WorkingDirectory=/home/YOUR_USER/topologygenerator
ExecStart=/home/YOUR_USER/topologygenerator/report.sh http://192.168.1.225:8770
Restart=always
RestartSec=10
# Environment=TOPO_TOKEN=your-shared-secret

[Install]
WantedBy=multi-user.target
